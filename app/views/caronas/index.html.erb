<div class="p-0">
  <%= image_tag 'banner_carona.png', class: "img-fluid w-100 shadow", style: "max-height: 300px; object-fit: cover;" %>
</div>

<% current_page = @caronas.current_page %>
 
<div class="my-3 col-11 ms-3">
  <%= search_form_for @q do |f| %>
    <div class="row align-items-end g-2">

      <%= render 'search_campus_index', f: f, role: 'departure', label_text: 'Partida' %>
      <%= render 'search_campus_index', f: f, role: 'destination', label_text: 'Destino' %>

      <div class="col-12 col-md-2 d-grid">
        <%= f.submit "Buscar", class: "btn btn-primary" %>
      </div>

    </div>
  <% end %>
</div>

<div class="order-2 order-md-1 mt-3 mt-md-0">
  <%= link_to 'Cadastrar Carona', new_carona_path, class: "btn btn-primary mb-3 ms-3" %>
</div>

<div class="row g-2 p-2 justify-content-center">
  <% @caronas.each do |carona| %>
    <div class="col-12 col-md-10 col-lg-8 col-xl-7 mb-3">
      <div class="card text-bg-primary">
        <div class="card-body rounded shadow py-3">
          <div class="d-flex flex-column flex-md-row align-items-center gap-3">

            <div class="text-center">
              <h5 class="mb-0"><strong><%= br_date_time(carona.date_time,'date') %></strong></h5>
              <h5 class="mb-0"><strong><%= br_date_time(carona.date_time,'time') %></strong></h5>
            </div>

            <div>
              <h5 class="mb-0">

                <% if carona.carona_paradas.any? %>
                  <strong>Com paradas</strong>

                <% else %>
                  <strong>Sem paradas</strong>
                <% end %>

              </h5>
            </div>
            
            <div class="d-flex align-items-stretch gap-2 mb-2">
              <div class="rounded" style="width: 4px; min-height: 80px; background-color: #ffffff;"></div>
              
              <div class="d-flex flex-column justify-content-between">
                <h5 class="mb-0 text" style="max-width: 600px;"><strong><%= carona.departure %></strong></h5>
                <h5 class="mb-0 text" style="max-width: 600px;"><strong><%= carona.destination %></strong></h5>
              </div>
            </div>
            
            <div class="flex-grow-1"></div>

            <div class="text-center">
              <h2 class="mb-0 text-white me-3"><strong><%= number_to_currency(carona.cost, unit: 'R$ ') %></strong></h2>
            </div>

          </div>
        </div>
        
        <div class="card-footer bg-light d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
          
          <div class="d-flex justify-content-start">
            <h5 class="mb-0 text-primary"><strong><%= carona.passengers_number %> Passageiros</strong></h5>
          </div>

          <div class="d-flex justify-content-center w-auto">
            <h5 class="text-dark mb-0"><strong><%= carona.driver_name %></strong></h5>
          </div>

          <div class="d-flex justify-content-end gap-2">
            <%= link_to 'Mostrar', carona_path(carona, page: current_page), class: "btn btn-dark", role: "button" %>
            <%= link_to 'Editar', edit_carona_path(carona, page: current_page), class: "btn btn-warning fw-bold", role: "button" %>
            <%= link_to 'Deletar', carona_path(carona, page: current_page), method: :delete, data: { confirm: 'Deseja deletar?' }, class: "btn btn-danger fw-bold", role: "button" %>
          </div>
        </div>
      </div>      
    </div>
  <% end %>
</div>


<br>

<div class="d-flex flex-column flex-md-row justify-content-md-between align-items-center mb-3 mt-4">

  <div class="order-1 order-md-2 mx-md-auto">
    <%= paginate @caronas %>
  </div>
  
</div>
